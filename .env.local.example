# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (Email) ────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# ── AI Provider (Ollama + Groq) ──────────────────────────────────────────────
# AI chat, insights, recommendations, and content generation use:
#   1. Ollama (local, free) — tried first
#   2. Groq (cloud, free tier) — fallback when Ollama is unavailable
#   3. Template fallback — when no AI provider is available
#
# Ollama (local dev): install from https://ollama.com, run `ollama pull llama3.1`
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
#
# Groq (production): get a free API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here
# Optional model overrides (defaults shown):
# GROQ_MODEL_CHAT=llama-3.3-70b-versatile
# GROQ_MODEL_FAST=llama-3.1-8b-instant

# ── Google OAuth (SSO + Calendar + Drive + Gmail) ────────────────────────────
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application type)
# 3. Add Authorized JavaScript origins:
#      https://app.gravissmarketing.com
#      http://localhost:3000 (for local dev)
# 4. Add Authorized redirect URIs:
#      https://app.gravissmarketing.com/api/calendar/callback  (Calendar)
#      https://app.gravissmarketing.com/api/drive/callback     (Drive)
#      http://localhost:3000/api/calendar/callback              (local dev)
#      http://localhost:3000/api/drive/callback                 (local dev)
# 5. Enable these APIs: Google Calendar API, Google Drive API, Gmail API
#
# CRITICAL: GOOGLE_CLIENT_ID and NEXT_PUBLIC_GOOGLE_CLIENT_ID MUST be identical.
# If they differ, Google SSO sign-in will fail with "audience mismatch".
# Use /api/auth/health to verify: clientIdMatch must be true.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://app.gravissmarketing.com/api/calendar/callback

# ── Google Ads API ───────────────────────────────────────────────────────────
# Developer token required on every Google Ads API request (in addition to OAuth).
# Apply at: https://ads.google.com/aw/apicenter (standard access required for prod)
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token

# ── Token Encryption ─────────────────────────────────────────────────────────
# Used to encrypt OAuth tokens at rest. Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=your-random-32-char-key-here

# ── Session Signing (REQUIRED in production) ──────────────────────────────────
# Signs the gravhub-auth session cookie so it can't be forged. Generate with:
# openssl rand -base64 48
# Must be set in Vercel (all environments) — requests fail closed (401) if unset
# in production. Rotating this value invalidates all existing sessions.
SESSION_SIGNING_KEY=your-random-48-char-key-here

# ── Cron (Vercel Cron) ───────────────────────────────────────────────────────
# Secret used to authenticate cron job requests. Generate with: openssl rand -base64 32
# For Vercel: set as CRON_SECRET in Vercel Environment Variables
CRON_SECRET=your-cron-secret-here

# ── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.gravissmarketing.com

# ── Meta (Facebook/Instagram) Ads API ───────────────────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ── Sentry (Error Tracking) ─────────────────────────────────────────────────
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.us.sentry.io/your-project-id
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
# Auth token for source map uploads (CI only):
# SENTRY_AUTH_TOKEN=sntrys_your-auth-token-here

# ── Web Push (VAPID) ───────────────────────────────────────────────────────
# Generate key pair: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:admin@gravissmarketing.com

# ── HubSpot ────────────────────────────────────────────────────────────────
# Get from: https://app.hubspot.com → Settings → Integrations → Private Apps
# HUBSPOT_API_KEY=your-hubspot-api-key

# ── Resend Webhook ─────────────────────────────────────────────────────────
# Signing secret for verifying Resend webhook payloads — used by both the
# outbound event webhook (opens/clicks/bounces) and the inbound "BCC to log"
# email capture (app/api/email/inbound). Get from: https://resend.com/webhooks
# RESEND_WEBHOOK_SECRET=your-resend-webhook-secret
#
# BCC-to-log ALSO requires a one-time DNS setup that can't be done from code:
# 1. Add a dedicated subdomain in Resend > Domains for receiving mail, e.g.
#    log.gravissmarketing.com (do NOT reuse the existing sending domain —
#    it already has SPF/DKIM and shares MX with real company mail).
# 2. Point that subdomain's MX records at Resend per their dashboard instructions.
# 3. Enable "Inbound" on that domain and set the webhook URL to
#    https://<your-app-url>/api/email/inbound
# 4. Update BCC_DOMAIN in app/api/gmail/token/route.ts if you used a different subdomain.

# ── Uptime Alerts ──────────────────────────────────────────────────────────
# "From" address for uptime alert emails
# UPTIME_ALERT_FROM=alerts@gravissmarketing.com

# ── LinkedIn OAuth ─────────────────────────────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps
# Used for LinkedIn integration in social media scheduling
# LINKEDIN_CLIENT_ID=your-linkedin-client-id
# LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ── Apollo (Lead Enrichment) ───────────────────────────────────────────────
# Get from: https://app.apollo.io/#/settings/integrations/api
# Used for enriching contacts with firmographic + person data
# APOLLO_API_KEY=your-apollo-api-key

# ── Maverick (Payment Processing) ──────────────────────────────────────────
# MAVERICK_API_KEY=your-maverick-key

# ── Mercury (Business Banking) ─────────────────────────────────────────────
# Get from: https://mercury.com → Settings → API
# Used for pulling account balances + transactions into the Finance module
# MERCURY_API_KEY=your-mercury-api-key

# ── IP Info (Visitor Identification) ───────────────────────────────────────
# Get from: https://ipinfo.io — free tier: 50K requests/mo
# Used by the /intelligence module for visitor geolocation
# IPINFO_API_KEY=your-ipinfo-token

# ── PageSpeed Insights (Core Web Vitals) ───────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → PageSpeed Insights API
# Free 25K queries/day. Used for site performance monitoring
# PAGESPEED_API_KEY=your-pagespeed-api-key

# ── WordPress Plugin ───────────────────────────────────────────────────────
# Shared secret for authenticating requests from the GravHub WordPress SEO
# plugin (installed on client sites). Generate: openssl rand -base64 32
# WORDPRESS_API_KEY=your-wordpress-plugin-secret

# ── Stripe (Payment Processing) ────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_your-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key


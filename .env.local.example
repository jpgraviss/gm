# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (Email) ────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# ── Anthropic (AI Insights) ───────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here
# Optional model overrides (defaults shown — latest Claude 4.x family)
# ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6
# ANTHROPIC_MODEL_INSIGHTS=claude-haiku-4-5-20251001

# ── Google OAuth (SSO + Calendar + Drive + Gmail) ────────────────────────────
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application type)
# 3. Add Authorized JavaScript origins:
#      https://app.gravissmarketing.com
#      http://localhost:3000 (for local dev)
# 4. Add Authorized redirect URIs:
#      https://app.gravissmarketing.com/api/calendar/callback  (Calendar)
#      https://app.gravissmarketing.com/api/drive/callback     (Drive)
#      http://localhost:3000/api/calendar/callback              (local dev)
#      http://localhost:3000/api/drive/callback                 (local dev)
# 5. Enable these APIs: Google Calendar API, Google Drive API, Gmail API
#
# CRITICAL: GOOGLE_CLIENT_ID and NEXT_PUBLIC_GOOGLE_CLIENT_ID MUST be identical.
# If they differ, Google SSO sign-in will fail with "audience mismatch".
# Use /api/auth/health to verify: clientIdMatch must be true.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://app.gravissmarketing.com/api/calendar/callback

# ── Google Ads API ───────────────────────────────────────────────────────────
# Developer token required on every Google Ads API request (in addition to OAuth).
# Apply at: https://ads.google.com/aw/apicenter (standard access required for prod)
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token

# ── QuickBooks Online (Intuit OAuth 2.0) ─────────────────────────────────────
# 1. Go to: https://developer.intuit.com/app/developer/myapps
# 2. Create app → select "QuickBooks Online and Payments"
# 3. Add Authorized Redirect URI: https://app.gravissmarketing.com/api/quickbooks/callback
# 4. Copy Client ID and Client Secret from Keys & credentials tab
QB_CLIENT_ID=your-intuit-client-id
QB_CLIENT_SECRET=your-intuit-client-secret
QB_REDIRECT_URI=https://app.gravissmarketing.com/api/quickbooks/callback
QB_ENVIRONMENT=production

# ── Token Encryption ─────────────────────────────────────────────────────────
# Used to encrypt OAuth tokens at rest. Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=your-random-32-char-key-here

# ── Cron (Vercel Cron) ───────────────────────────────────────────────────────
# Secret used to authenticate cron job requests. Generate with: openssl rand -base64 32
# For Vercel: set as CRON_SECRET in Vercel Environment Variables
CRON_SECRET=your-cron-secret-here

# ── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.gravissmarketing.com

# ── Meta (Facebook/Instagram) Ads API ───────────────────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ── Sentry (Error Tracking) ─────────────────────────────────────────────────
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.us.sentry.io/your-project-id
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
# Auth token for source map uploads (CI only):
# SENTRY_AUTH_TOKEN=sntrys_your-auth-token-here

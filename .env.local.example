# ─── Google OAuth (Sign in with Google) + Gmail API ───────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Click the OAuth 2.0 Client ID: 814604774873-ksk94ckpbgidnno8mknpms6n5bcht23t
# 3. Under "Authorized JavaScript origins" add ALL THREE:
#      http://localhost:3000                  (local development)
#      https://app.gravissmarketing.com       (production)
#      https://gm-psi-drab.vercel.app         (Vercel preview)
# 4. Enable Gmail API: APIs & Services → Library → Gmail API → Enable
# 5. Save — changes take ~5 minutes to propagate
# 6. On Vercel (project: gm) set NEXT_PUBLIC_GOOGLE_CLIENT_ID + NEXT_PUBLIC_APP_URL

NEXT_PUBLIC_GOOGLE_CLIENT_ID=814604774873-ksk94ckpbgidnno8mknpms6n5bcht23t.apps.googleusercontent.com

# ─── Resend (transactional email — forgot-password, invites, portal) ──────────
# 1. Sign up at https://resend.com (free tier: 3,000 emails/month)
# 2. Go to API Keys → Create API Key (name it "gravhub-production")
# 3. Verify your sending domain: Domains → Add Domain → gravissmarketing.com
#    Add the DNS records Resend provides (SPF, DKIM, DMARC)
# 4. Set these two variables:

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The public URL of your deployment (used in email links).
# Local dev: http://localhost:3000 | Production: https://app.gravissmarketing.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

